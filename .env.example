DOCAPI_ENV=dev

# Understanding step.
#   stub    = free, no network, no key (default; returns placeholders)
#   ollama  = free, local model (requires `ollama serve` + a pulled model)
#   anthropic = paid (not wired yet)
LLM_PROVIDER=stub
LLM_MODEL=llama3.2            # used by the ollama provider
ANTHROPIC_API_KEY=
OLLAMA_HOST=http://localhost:11434

MAX_FILE_MB=20
MAX_PAGES=30
REQUEST_TIMEOUT_SECONDS=60
